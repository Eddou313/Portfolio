---
type ProjectData = {
    order?: number;
    slug: string;
    badge: LocalizedText;
    image: string;
    imageAlt: LocalizedText;
    title: LocalizedText;
    description: LocalizedText;
    technologies: string[];
    repoUrl: string;
    details: {
        description: LocalizedText;
        points: LocalizedStringArray;
        images?: Array<{
            src: string;
            alt?: LocalizedText;
            caption?: LocalizedText;
        }>;
    };
};

type LocalizedText = string | { en?: string; fr?: string };
type LocalizedStringArray = string[] | { en?: string[]; fr?: string[] };

function resolveLocalizedText(value: LocalizedText | undefined, lang: 'en' | 'fr', fallbackLang: 'en' | 'fr' = 'en'): string {
    if (!value) return '';
    if (typeof value === 'string') return value;
    return value[lang] ?? value[fallbackLang] ?? value.en ?? value.fr ?? '';
}

function resolveLocalizedArray(value: LocalizedStringArray | undefined, lang: 'en' | 'fr', fallbackLang: 'en' | 'fr' = 'en'): string[] {
    if (!value) return [];
    if (Array.isArray(value)) return value;
    return value[lang] ?? value[fallbackLang] ?? value.en ?? value.fr ?? [];
}

function resolveProjectText(value: LocalizedText | undefined): { en: string; fr: string } {
    // Si c'est une simple string, on la retourne pour les deux langues
    if (typeof value === 'string') return { en: value, fr: value };
    
    const en = resolveLocalizedText(value, 'en', 'fr');
    const fr = resolveLocalizedText(value, 'fr', 'en');
    return { en, fr };
}

function resolveProjectArray(value: LocalizedStringArray | undefined): { en: string[]; fr: string[] } {
    if (Array.isArray(value)) return { en: value, fr: value };
    
    const en = resolveLocalizedArray(value, 'en', 'fr');
    const fr = resolveLocalizedArray(value, 'fr', 'en');
    return { en, fr };
}

const projectModules = import.meta.glob('../../../data/projets/*.json', { eager: true, import: 'default' });
const projects = Object.values(projectModules) as ProjectData[];
projects.sort((a, b) => (a.order ?? 999) - (b.order ?? 999));

---
<section id="projects" class="min-h-screen py-20 px-4 bg-gray-50 dark:bg-gray-800/50 flex flex-col justify-center relative">
    <div class="max-w-6xl mx-auto w-full">
        <div class="text-center mb-14">
            <h2
                data-en="My Projects"
                data-fr="Mes Projets"
                class="section-text text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4"
            >
                My Projects
            </h2>
            <div class="w-20 h-1 bg-amber-400 mx-auto rounded-full"></div>
            <p data-en="Some of my recent work" data-fr="Quelques-uns de mes travaux recents" class="section-text mt-6 text-gray-600 dark:text-gray-400 text-lg">Some of my recent work</p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {projects.map((project) => {
                const badge = resolveProjectText(project.badge);
                const imageAlt = resolveProjectText(project.imageAlt);
                const title = resolveProjectText(project.title);
                const description = resolveProjectText(project.description);
                const detailsDescription = resolveProjectText(project.details.description);
                const detailsPoints = resolveProjectArray(project.details.points);
                const detailsImagesEn = (project.details.images ?? []).map((image) => ({
                    src: image.src,
                    alt: resolveProjectText(image.alt).en,
                    caption: resolveProjectText(image.caption).en
                }));
                const detailsImagesFr = (project.details.images ?? []).map((image) => ({
                    src: image.src,
                    alt: resolveProjectText(image.alt).fr,
                    caption: resolveProjectText(image.caption).fr
                }));

                return (
                <div class="relative rounded-2xl overflow-hidden border border-gray-200 dark:border-indigo-700/60 bg-white dark:bg-slate-900/80 shadow-lg shadow-black/10 dark:shadow-black/30 hover:-translate-y-1 hover:shadow-xl transition-all h-full flex flex-col">
                    {/* --- CORRECTION ICI POUR LE BADGE --- */}
                    <span 
                        data-en={badge.en} 
                        data-fr={badge.fr} 
                        class="project-i18n absolute top-3 right-3 z-10 inline-flex items-center gap-1.5 rounded-full bg-amber-400 px-3 py-1 text-xs font-semibold text-slate-900"
                    >
                        {badge.en}
                    </span>
                    
                    <img
                        src={project.image}
                        alt={imageAlt.en}
                        data-en-alt={imageAlt.en}
                        data-fr-alt={imageAlt.fr}
                        class="project-cover h-52 w-full object-cover"
                        loading="lazy"
                    />
                    <div class="p-5 flex flex-1 flex-col">
                        <h3 data-en={title.en} data-fr={title.fr} class="project-i18n text-2xl font-bold text-gray-900 dark:text-slate-100 mb-2">{title.en}</h3>
                        <p data-en={description.en} data-fr={description.fr} class="project-i18n text-gray-600 dark:text-slate-300/90 leading-relaxed">{description.en}</p>
                        <div class="mt-4 flex flex-wrap gap-2">
                            {project.technologies.map((tech) => (
                                <span class="px-2.5 py-1 rounded-md bg-gray-100 dark:bg-slate-800 text-amber-700 dark:text-amber-300 text-xs font-semibold">{tech}</span>
                            ))}
                        </div>
                        <div class="mt-auto pt-4 border-t border-gray-200 dark:border-indigo-700/60 flex items-center justify-between gap-3">
                            <a
                                href={project.repoUrl}
                                target="_blank"
                                rel="noopener noreferrer"
                                data-en="View code"
                                data-fr="Voir le code"
                                class="project-i18n inline-flex items-center gap-2 text-indigo-700 dark:text-amber-300 hover:text-indigo-900 dark:hover:text-amber-200 font-semibold text-sm"
                            >
                                <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6" />
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12H3" />
                                </svg>
                                <span class="project-i18n-text">View code</span>
                            </a>
                            <button
                                type="button"
                                class="project-i18n project-detail-btn text-indigo-700 dark:text-amber-300 hover:text-indigo-900 dark:hover:text-amber-200 font-semibold text-sm"
                                data-en="View details"
                                data-fr="Voir les details"
                                data-project={project.slug}
                                data-description-en={detailsDescription.en}
                                data-description-fr={detailsDescription.fr}
                                data-points-en={detailsPoints.en.join('||')}
                                data-points-fr={detailsPoints.fr.join('||')}
                                data-images-en={JSON.stringify(detailsImagesEn)}
                                data-images-fr={JSON.stringify(detailsImagesFr)}
                            >
                                <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14" />
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14" />
                                </svg>
                                <span class="project-i18n-text">View details</span>
                            </button>
                        </div>
                    </div>
                </div>
            );
            })}
        </div>

        {/* ... (Reste du code pour les modals et lightboxes inchangé) ... */}
        <div id="project-modal" class="fixed inset-0 z-[80] hidden" aria-hidden="true">
            <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" data-project-close></div>
            <div class="relative z-10 flex items-center justify-center min-h-full p-4">
                    <div class="w-[80vw] max-w-none max-h-[calc(100vh-2rem)] overflow-hidden rounded-2xl border border-gray-200 dark:border-indigo-700 bg-white dark:bg-slate-900 text-gray-900 dark:text-slate-100 shadow-2xl shadow-black/30 dark:shadow-black/70 flex flex-col" role="dialog" aria-modal="true" aria-labelledby="project-modal-title">
                    <div class="flex items-center justify-between gap-4 border-b border-gray-200 dark:border-indigo-700 px-5 py-4">
                        <h3 id="project-modal-title" data-en="Project details" data-fr="Details du projet" class="project-i18n text-xl font-bold">Project details</h3>
                        <button type="button" id="project-modal-close" data-en="Close" data-fr="Fermer" class="project-i18n rounded-lg border border-gray-300 dark:border-indigo-600 px-3 py-2 text-sm hover:bg-gray-100 dark:hover:bg-slate-800 transition-colors">Close</button>
                    </div>
                        <div class="flex-1 overflow-y-auto p-5">
                        <p id="project-modal-description" class="text-gray-700 dark:text-slate-300/95 leading-relaxed"></p>
                        <ul id="project-modal-list" class="mt-4 space-y-2 text-gray-700 dark:text-slate-300/90 list-disc pl-5"></ul>
                        <div id="project-modal-gallery" class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-4"></div>
                    </div>
                </div>
            </div>
        </div>

        <div id="project-lightbox" class="fixed inset-0 z-[90] hidden" aria-hidden="true">
            <div class="absolute inset-0 bg-black/90" data-lightbox-close></div>
            <div class="relative z-10 flex items-center justify-center min-h-full px-4 py-8">
                <button
                    type="button"
                    id="project-lightbox-close"
                    data-en="Close image"
                    data-fr="Fermer l'image"
                    class="project-i18n absolute top-6 right-6 inline-flex items-center justify-center w-11 h-11 rounded-full border border-white/30 bg-black/40 text-white hover:bg-black/60 transition-colors"
                    aria-label="Close image"
                >
                    <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 6l12 12" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M18 6L6 18" />
                    </svg>
                    <span class="project-i18n-text sr-only">Close image</span>
                </button>

                <button
                    type="button"
                    id="project-lightbox-prev"
                    data-en="Previous image"
                    data-fr="Image precedente"
                    class="project-i18n absolute left-4 md:left-8 inline-flex items-center justify-center w-11 h-11 rounded-full border border-white/30 bg-black/40 text-white hover:bg-black/60 transition-colors"
                    aria-label="Previous image"
                >
                    <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 18l-6-6 6-6" />
                    </svg>
                    <span class="project-i18n-text sr-only">Previous image</span>
                </button>

                <div class="w-full max-w-6xl">
                    <figure class="w-full">
                        <img id="project-lightbox-image" src="" alt="" class="w-full max-h-[75vh] object-contain" loading="eager" decoding="async" />
                        <figcaption id="project-lightbox-caption" class="mt-4 text-center text-sm md:text-base text-white/90"></figcaption>
                    </figure>
                </div>

                <button
                    type="button"
                    id="project-lightbox-next"
                    data-en="Next image"
                    data-fr="Image suivante"
                    class="project-i18n absolute right-4 md:right-8 inline-flex items-center justify-center w-11 h-11 rounded-full border border-white/30 bg-black/40 text-white hover:bg-black/60 transition-colors"
                    aria-label="Next image"
                >
                    <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 18l6-6-6-6" />
                    </svg>
                    <span class="project-i18n-text sr-only">Next image</span>
                </button>
            </div>
        </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
        <a href="#contact" aria-label="Scroll to Contact section" class="inline-flex items-center justify-center w-12 h-12 rounded-full text-gray-400 dark:text-slate-300 hover:text-amber-300 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-amber-300">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
            </svg>
        </a>
    </div>
</section>