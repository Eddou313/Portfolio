---
const navItems = [
  { name: 'Home', nameFr: 'Accueil', href: '#home' },
  { name: 'About', nameFr: 'À propos', href: '#about' },
  { name: 'Skills', nameFr: 'Compétences', href: '#skills' },
  { name: 'Formation', nameFr: 'Formation', href: '#formation' },
  { name: 'Projects', nameFr: 'Projets', href: '#projects' },
  { name: 'Blog', nameFr: 'Blog', href: '#blog' },
  { name: 'Contact', nameFr: 'Contact', href: '#contact' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white dark:bg-gray-800 shadow-sm transition-colors duration-300">
  <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="text-xl font-bold text-gray-900 dark:text-white hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
      Me.
    </a>
    
    <div class="flex items-center gap-3">
      <!-- Download CV Button -->
      <a 
        href="/cv/CV_Eddou.pdf" 
        download="CV_Eddou.pdf"
        class="flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 rounded-lg transition-colors shadow-sm hover:shadow-md"
        title="Download CV"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
        </svg>
        <span class="hidden sm:inline" data-en="CV" data-fr="CV">CV</span>
      </a>

      <!-- Language Switcher -->
      <div class="relative">
        <button 
          id="lang-toggle" 
          class="flex items-center gap-1.5 px-3 py-1.5 text-sm font-medium text-gray-600 dark:text-gray-300 bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 rounded-lg transition-colors"
          aria-label="Change language"
        >
          <span id="current-lang-flag">🇬🇧</span>
          <span id="current-lang-text">EN</span>
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div id="lang-dropdown" class="hidden absolute right-0 mt-2 w-32 bg-white dark:bg-gray-700 rounded-lg shadow-lg border border-gray-200 dark:border-gray-600 overflow-hidden">
          <button data-lang="en" class="lang-option w-full flex items-center gap-2 px-3 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-indigo-50 dark:hover:bg-gray-600 transition-colors">
            <span>🇬🇧</span> English
          </button>
          <button data-lang="fr" class="lang-option w-full flex items-center gap-2 px-3 py-2 text-sm text-gray-700 dark:text-gray-200 hover:bg-indigo-50 dark:hover:bg-gray-600 transition-colors">
            <span>🇫🇷</span> Français
          </button>
        </div>
      </div>

      <!-- Theme Toggle -->
      <button 
        id="theme-toggle" 
        class="relative w-14 h-7 bg-gray-200 dark:bg-gray-600 rounded-full p-1 transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-indigo-500"
        aria-label="Toggle theme"
      >
        <span class="sr-only">Toggle dark mode</span>
        <span 
          id="toggle-ball"
          class="absolute left-1 top-1 w-5 h-5 bg-white rounded-full shadow-md transform transition-transform duration-300 flex items-center justify-center"
        >
          <!-- Sun icon -->
          <svg id="sun-icon" class="w-3 h-3 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z" clip-rule="evenodd"/>
          </svg>
          <!-- Moon icon -->
          <svg id="moon-icon" class="w-3 h-3 text-indigo-600 hidden" fill="currentColor" viewBox="0 0 20 20">
            <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/>
          </svg>
        </span>
      </button>
      
      <button id="menu-btn" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Menu">
        <span class="w-6 h-0.5 bg-gray-900 dark:bg-white transition-all"></span>
        <span class="w-6 h-0.5 bg-gray-900 dark:bg-white transition-all"></span>
        <span class="w-6 h-0.5 bg-gray-900 dark:bg-white transition-all"></span>
      </button>
    </div>
    
    <ul id="nav-links" class="hidden md:flex items-center gap-1">
      {navItems.map((item) => (
        <li>
          <a 
            href={item.href} 
            data-en={item.name}
            data-fr={item.nameFr}
            data-section={item.href.replace('#', '')}
            class="nav-item px-4 py-2 text-sm font-medium text-gray-600 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-gray-700 rounded-lg transition-all relative"
          >
            {item.name}
          </a>
        </li>
      ))}
    </ul>
  </div>
  
  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden fixed inset-0 bg-white dark:bg-gray-800 z-40 md:hidden transition-colors duration-300">
    <ul class="flex flex-col items-center justify-center h-full gap-4">
      {navItems.map((item) => (
        <li>
          <a 
            href={item.href} 
            data-en={item.name}
            data-fr={item.nameFr}
            data-section={item.href.replace('#', '')}
            class="nav-item mobile-nav-item text-lg font-medium text-gray-700 dark:text-gray-200 hover:text-indigo-600 dark:hover:text-indigo-400 px-6 py-3 transition-colors"
          >
            {item.name}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const themeToggle = document.getElementById('theme-toggle');
  const toggleBall = document.getElementById('toggle-ball');
  const sunIcon = document.getElementById('sun-icon');
  const moonIcon = document.getElementById('moon-icon');
  const langToggle = document.getElementById('lang-toggle');
  const langDropdown = document.getElementById('lang-dropdown');
  const currentLangFlag = document.getElementById('current-lang-flag');
  const currentLangText = document.getElementById('current-lang-text');

  // Mobile menu toggle
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  document.querySelectorAll('#mobile-menu a').forEach(link => {
    link.addEventListener('click', () => menu?.classList.add('hidden'));
  });

  // Language switcher
  function setLanguage(lang: string) {
    localStorage.setItem('lang', lang);
    document.documentElement.setAttribute('data-lang', lang);
    
    // Update button display
    if (lang === 'fr') {
      currentLangFlag!.textContent = '🇫🇷';
      currentLangText!.textContent = 'FR';
    } else {
      currentLangFlag!.textContent = '🇬🇧';
      currentLangText!.textContent = 'EN';
    }
    
    // Update all nav items
    document.querySelectorAll('.nav-item').forEach(item => {
      const text = item.getAttribute(`data-${lang}`);
      if (text) item.textContent = text;
    });
    
    // Dispatch event for other components
    window.dispatchEvent(new CustomEvent('langchange', { detail: { lang } }));
  }

  // Initialize language
  const savedLang = localStorage.getItem('lang') || 'en';
  setLanguage(savedLang);

  // Toggle dropdown
  langToggle?.addEventListener('click', (e) => {
    e.stopPropagation();
    langDropdown?.classList.toggle('hidden');
  });

  // Select language
  document.querySelectorAll('.lang-option').forEach(option => {
    option.addEventListener('click', () => {
      const lang = option.getAttribute('data-lang') || 'en';
      setLanguage(lang);
      langDropdown?.classList.add('hidden');
    });
  });

  // Close dropdown when clicking outside
  document.addEventListener('click', () => {
    langDropdown?.classList.add('hidden');
  });

  // Theme toggle
  function updateThemeIcons() {
    const isDark = document.documentElement.classList.contains('dark');
    if (toggleBall) {
      toggleBall.style.transform = isDark ? 'translateX(1.75rem)' : 'translateX(0)';
    }
    sunIcon?.classList.toggle('hidden', isDark);
    moonIcon?.classList.toggle('hidden', !isDark);
  }

  // Initialize icons on load
  updateThemeIcons();

  themeToggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    updateThemeIcons();
  });

  // Active section highlighting
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('#nav-links .nav-item');
  const mobileNavLinks = document.querySelectorAll('.mobile-nav-item');

  function setActiveLink(sectionId: string) {
    // Desktop nav
    navLinks.forEach(link => {
      const linkSection = link.getAttribute('data-section');
      if (linkSection === sectionId) {
        link.classList.add('text-indigo-600', 'dark:text-indigo-400', 'bg-indigo-50', 'dark:bg-gray-700');
        link.classList.remove('text-gray-600', 'dark:text-gray-300');
        // Add underline
        if (!link.querySelector('.active-indicator')) {
          const indicator = document.createElement('span');
          indicator.className = 'active-indicator absolute bottom-0 left-1/2 -translate-x-1/2 w-6 h-0.5 bg-indigo-600 dark:bg-indigo-400 rounded-full';
          link.appendChild(indicator);
        }
      } else {
        link.classList.remove('text-indigo-600', 'dark:text-indigo-400', 'bg-indigo-50', 'dark:bg-gray-700');
        link.classList.add('text-gray-600', 'dark:text-gray-300');
        // Remove underline
        const indicator = link.querySelector('.active-indicator');
        if (indicator) indicator.remove();
      }
    });

    // Mobile nav
    mobileNavLinks.forEach(link => {
      const linkSection = link.getAttribute('data-section');
      if (linkSection === sectionId) {
        link.classList.add('text-indigo-600', 'dark:text-indigo-400');
        link.classList.remove('text-gray-700', 'dark:text-gray-200');
      } else {
        link.classList.remove('text-indigo-600', 'dark:text-indigo-400');
        link.classList.add('text-gray-700', 'dark:text-gray-200');
      }
    });
  }

  // Intersection Observer for detecting active section
  const observerOptions = {
    root: null,
    rootMargin: '-20% 0px -70% 0px',
    threshold: 0
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        setActiveLink(entry.target.id);
      }
    });
  }, observerOptions);

  sections.forEach(section => observer.observe(section));

  // Set initial active state based on hash or first section
  const initialSection = window.location.hash.replace('#', '') || 'home';
  setActiveLink(initialSection);
</script>
