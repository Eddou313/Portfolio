---
import Layout from '../layouts/Layout.astro';
import AboutSection from '../components/sections/AboutSection.astro';
import SkillsSection from '../components/sections/SkillsSection.astro';
import FormationSection from '../components/sections/FormationSection.astro';
import ProjectsSection from '../components/sections/ProjectsSection.astro';
import homeData from '../../data/home/content.json';
import contactData from '../../data/contact/content.json';
---

<Layout>
	<!-- Hero Section -->
	<section id="home" class="min-h-screen flex items-center justify-center px-4 py-20">
		<div class="max-w-4xl mx-auto text-center">
			<!-- Avatar -->
			<div class="mb-8">
				<div class="w-40 h-40 md:w-52 md:h-52 mx-auto rounded-full bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-white text-5xl md:text-6xl font-bold shadow-xl ring-4 ring-white dark:ring-gray-800">
					{homeData.avatarInitials}
				</div>
			</div>

			<!-- Greeting -->
			<p 
				data-en={homeData.greeting.en}
				data-fr={homeData.greeting.fr}
				class="hero-text text-lg text-indigo-600 dark:text-indigo-400 font-medium mb-2"
			>
				{homeData.greeting.en}
			</p>

			<!-- Name -->
			<h1 class="text-4xl md:text-6xl font-bold text-gray-900 dark:text-white mb-4">
				{homeData.name}
			</h1>

			<!-- Title -->
			<h2 
				data-en={homeData.title.en}
				data-fr={homeData.title.fr}
				class="hero-text text-xl md:text-2xl text-gray-600 dark:text-gray-300 mb-6"
			>
				{homeData.title.en}
			</h2>

			<!-- Description -->
			<p 
				data-en={homeData.description.en}
				data-fr={homeData.description.fr}
				class="hero-text text-gray-600 dark:text-gray-400 max-w-2xl mx-auto mb-8 leading-relaxed"
			>
				{homeData.description.en}
			</p>

			<!-- CTA Buttons -->
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<a 
					href={homeData.cta.primary.href}
					data-en={homeData.cta.primary.en}
					data-fr={homeData.cta.primary.fr}
					class="hero-text px-8 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg transition-colors shadow-md hover:shadow-lg"
				>
					{homeData.cta.primary.en}
				</a>
				<a 
					href={homeData.cta.secondary.href}
					data-en={homeData.cta.secondary.en}
					data-fr={homeData.cta.secondary.fr}
					class="hero-text px-8 py-3 border-2 border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:border-indigo-600 hover:text-indigo-600 dark:hover:border-indigo-400 dark:hover:text-indigo-400 font-medium rounded-lg transition-colors"
				>
					{homeData.cta.secondary.en}
				</a>
			</div>

			<!-- Social Links -->
			<div class="mt-12">
				<div class="flex justify-center gap-5">
					<!-- GitHub -->
					<a 
						href={homeData.social.github}
						target="_blank"
						rel="noopener noreferrer"
						aria-label="GitHub"
						class="w-12 h-12 flex items-center justify-center rounded-full bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-900 hover:text-white dark:hover:bg-white dark:hover:text-gray-900 transition-all hover:scale-110"
					>
						<svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
							<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
						</svg>
					</a>

					<!-- LinkedIn -->
					<a 
						href={homeData.social.linkedin}
						target="_blank"
						rel="noopener noreferrer"
						aria-label="LinkedIn"
						class="w-12 h-12 flex items-center justify-center rounded-full bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-blue-600 hover:text-white transition-all hover:scale-110"
					>
						<svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
							<path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
						</svg>
					</a>

					<!-- Email -->
					<a 
						href={homeData.social.email}
						aria-label="Email"
						class="w-12 h-12 flex items-center justify-center rounded-full bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-red-500 hover:text-white transition-all hover:scale-110"
					>
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
						</svg>
					</a>

					<!-- WhatsApp -->
					<a 
						href={homeData.social.whatsapp}
						target="_blank"
						rel="noopener noreferrer"
						aria-label="WhatsApp"
						class="w-12 h-12 flex items-center justify-center rounded-full bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-green-500 hover:text-white transition-all hover:scale-110"
					>
						<svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
							<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
						</svg>
					</a>
				</div>
			</div>

			<!-- Scroll indicator -->
			<div class="mt-16 animate-bounce">
				<a href="#about" aria-label="Scroll to About section" class="inline-flex items-center justify-center w-12 h-12 rounded-full text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500">
					<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
					</svg>
				</a>
			</div>
		</div>
	</section>

	<AboutSection />

	<SkillsSection />

	<FormationSection />

	<ProjectsSection />

	<!-- Contact Section -->
	<section id="contact" class="min-h-screen py-20 px-4 bg-gray-50 dark:bg-gray-800/50 flex flex-col justify-center relative">
		<div class="max-w-4xl mx-auto w-full">
			<!-- Section Title -->
			<div class="text-center mb-16">
				<h2 
					data-en={contactData.title.en}
					data-fr={contactData.title.fr}
					class="section-text text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4"
				>
					{contactData.title.en}
				</h2>
				<div class="w-20 h-1 bg-indigo-600 mx-auto rounded-full"></div>
				<p 
					data-en={contactData.subtitle.en}
					data-fr={contactData.subtitle.fr}
					class="section-text mt-4 text-gray-600 dark:text-gray-400"
				>
					{contactData.subtitle.en}
				</p>
			</div>

			<!-- Contact Form -->
			<form
				id="contact-form"
				class="space-y-6"
				action={`https://formsubmit.co/${contactData.info.email}`}
				method="POST"
			>
				<input type="hidden" name="_captcha" value="false">
				<input type="hidden" name="_subject" value="Nouveau message depuis le portfolio">
				<input type="hidden" name="_template" value="table">
				<div class="grid md:grid-cols-2 gap-6">
					<div>
						<label for="name" data-en={contactData.form.name.en} data-fr={contactData.form.name.fr} class="section-text block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">{contactData.form.name.en}</label>
						<input 
							type="text" 
							id="name" 
							name="name"
							required
							class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-colors"
							placeholder={contactData.form.name.placeholder}
						>
					</div>
					<div>
						<label for="email" data-en={contactData.form.email.en} data-fr={contactData.form.email.fr} class="section-text block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">{contactData.form.email.en}</label>
						<input 
							type="email" 
							id="email" 
							name="email"
							required
							class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-colors"
							placeholder={contactData.form.email.placeholder}
						>
					</div>
				</div>
				<div>
					<label for="subject" data-en={contactData.form.subject.en} data-fr={contactData.form.subject.fr} class="section-text block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">{contactData.form.subject.en}</label>
					<input 
						type="text" 
						id="subject" 
						name="subject"
						required
						class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-colors"
						placeholder={contactData.form.subject.placeholder}
					>
				</div>
				<div>
					<label for="message" data-en={contactData.form.message.en} data-fr={contactData.form.message.fr} class="section-text block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">{contactData.form.message.en}</label>
					<textarea 
						id="message" 
						name="message"
						required
						rows="5"
						class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-colors resize-none"
						placeholder={contactData.form.message.placeholder}
					></textarea>
				</div>
				<div class="text-center">
					<button 
						type="submit"
						data-en={contactData.form.submit.en}
						data-fr={contactData.form.submit.fr}
						class="section-text px-8 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg transition-colors inline-flex items-center gap-2"
					>
						<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
						</svg>
						{contactData.form.submit.en}
					</button>
					<p id="contact-status" class="section-text mt-4 text-sm text-gray-600 dark:text-gray-300" aria-live="polite"></p>
				</div>
			</form>

			<!-- Contact Info -->
			<div class="mt-16 flex flex-wrap justify-center gap-8">
				<a href={`mailto:${contactData.info.email}`} class="flex items-center gap-3 text-gray-600 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
					<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
					</svg>
					<span>{contactData.info.email}</span>
				</a>
				<a href="https://wa.me/+261327517278" class="flex items-center gap-3 text-gray-600 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
					<svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
						<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
					</svg>
					<span>{contactData.info.whatsapp}</span>
				</a>
			</div>
		</div>
	</section>
</Layout>

<script>
	function updateLang(lang: string) {
		document.querySelectorAll('.hero-text, .about-text, .section-text').forEach(el => {
			const text = el.getAttribute(`data-${lang}`);
			if (text) el.textContent = text;
		});
	}

	// Initialize
	let currentLang = localStorage.getItem('lang') || 'en';
	updateLang(currentLang);

	const contactForm = document.querySelector<HTMLFormElement>('#contact-form');
	const contactStatus = document.querySelector<HTMLElement>('#contact-status');
	const contactEmail = contactForm?.action.replace('https://formsubmit.co/', '').trim() || '';
	const projectModal = document.querySelector<HTMLElement>('#project-modal');
	const projectModalClose = document.querySelector<HTMLButtonElement>('#project-modal-close');
	const projectModalDescription = document.querySelector<HTMLElement>('#project-modal-description');
	const projectModalList = document.querySelector<HTMLElement>('#project-modal-list');

	function closeProjectModal() {
		if (!projectModal) return;
		projectModal.classList.add('hidden');
		projectModal.setAttribute('aria-hidden', 'true');
		document.body.classList.remove('overflow-hidden');
	}

	document.querySelectorAll<HTMLButtonElement>('.project-detail-btn').forEach((btn) => {
		btn.addEventListener('click', () => {
			if (!projectModal || !projectModalDescription || !projectModalList) return;
			const description = btn.dataset.description || '';
			const points = (btn.dataset.points || '')
				.split('||')
				.map((point) => point.trim())
				.filter(Boolean);

			projectModalDescription.textContent = description;
			projectModalList.innerHTML = points.map((point) => `<li>${point}</li>`).join('');
			projectModal.classList.remove('hidden');
			projectModal.setAttribute('aria-hidden', 'false');
			document.body.classList.add('overflow-hidden');
		});
	});

	projectModalClose?.addEventListener('click', closeProjectModal);
	projectModal?.querySelector<HTMLElement>('[data-project-close]')?.addEventListener('click', closeProjectModal);
	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape') closeProjectModal();
	});

	if (contactForm && contactStatus) {
		contactForm.addEventListener('submit', async (event) => {
			event.preventDefault();
			
			const formData = new FormData(contactForm);
			const emailToVerify = formData.get('email') as string;
			
			// 1. Message de début de vérification
			contactStatus.textContent = currentLang === 'fr' ? 'Vérification de l\'email...' : 'Verifying email...';

			try {
				// --- ÉTAPE DE VÉRIFICATION DE L'EXISTENCE ---
				// Remplace 'TON_API_KEY' par ta clé Abstract API
				const apiKey = 'TON_API_KEY'; 
				const verifyRes = await fetch(`https://emailvalidation.abstractapi.com/v1/?api_key=${apiKey}&email=${emailToVerify}`);
				const verifyData = await verifyRes.json();

				// On vérifie si l'email est considéré comme valide (deliverability)
				// 'DELIVERABLE' signifie que l'adresse existe probablement
				if (verifyData.deliverability === 'UNDELIVERABLE') {
					contactStatus.textContent = currentLang === 'fr' 
						? "L'adresse email semble invalide ou n'existe pas." 
						: "The email address seems invalid or doesn't exist.";
					contactStatus.classList.add('text-red-500');
					return; // On arrête tout ici
				}

				// --- ÉTAPE D'ENVOI SI OK ---
				contactStatus.textContent = currentLang === 'fr' ? 'Envoi en cours...' : 'Sending...';

				const response = await fetch(`https://formsubmit.co/ajax/${contactEmail}`, {
					method: 'POST',
					headers: { 'Accept': 'application/json' },
					body: formData
				});

				if (!response.ok) throw new Error('Form submission failed');

				contactForm.reset();
				contactStatus.classList.replace('text-red-500', 'text-green-500');
				contactStatus.textContent = currentLang === 'fr'
					? 'Message envoyé avec succès. Je vous répondrai bientôt.'
					: 'Message sent successfully. I will reply soon.';

			} catch (error) {
				contactStatus.textContent = currentLang === 'fr'
					? `Une erreur est survenue. Réessayez ou écrivez à ${contactEmail}.`
					: `An error occurred. Please try again or email me at ${contactEmail}.`;
			}
		});
	}
	

	// Listen for language changes
	window.addEventListener('langchange', (e: Event) => {
		currentLang = (e as CustomEvent).detail.lang;
		updateLang(currentLang);
	});
</script>
