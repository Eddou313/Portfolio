---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<!-- Hero Section -->
	<section id="home" class="min-h-screen flex items-center justify-center px-4 py-20">
		<div class="max-w-4xl mx-auto text-center">
			<!-- Avatar -->
			<div class="mb-8">
				<div class="w-40 h-40 md:w-52 md:h-52 mx-auto rounded-full bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-white text-5xl md:text-6xl font-bold shadow-xl ring-4 ring-white dark:ring-gray-800">
					ED
				</div>
			</div>

			<!-- Greeting -->
			<p 
				data-en="Hello, I'm" 
				data-fr="Bonjour, je suis"
				class="hero-text text-lg text-indigo-600 dark:text-indigo-400 font-medium mb-2"
			>
				Hello, I'm
			</p>

			<!-- Name -->
			<h1 class="text-4xl md:text-6xl font-bold text-gray-900 dark:text-white mb-4">
				Randrianarison Eddou
			</h1>

			<!-- Title -->
			<h2 
				data-en="Full-Stack Developper" 
				data-fr="Développeur Full-Stack"
				class="hero-text text-xl md:text-2xl text-gray-600 dark:text-gray-300 mb-6"
			>
				Full-Stack Developper
			</h2>

			<!-- Description -->
			<p 
				data-en="Passionate about creating modern web applications and bringing ideas to life through clean code and intuitive design." 
				data-fr="Passionné par la création d'applications web modernes et donner vie aux idées grâce à un code propre et un design intuitif."
				class="hero-text text-gray-600 dark:text-gray-400 max-w-2xl mx-auto mb-8 leading-relaxed"
			>
				Passionate about creating modern web applications and bringing ideas to life through clean code and intuitive design.
			</p>

			<!-- CTA Buttons -->
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<a 
					href="#projects" 
					data-en="View My Work"
					data-fr="Voir mes projets"
					class="hero-text px-8 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-lg transition-colors shadow-md hover:shadow-lg"
				>
					View My Work
				</a>
				<a 
					href="#contact" 
					data-en="Contact Me"
					data-fr="Me contacter"
					class="hero-text px-8 py-3 border-2 border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:border-indigo-600 hover:text-indigo-600 dark:hover:border-indigo-400 dark:hover:text-indigo-400 font-medium rounded-lg transition-colors"
				>
					Contact Me
				</a>
			</div>

			<!-- Social Links -->
			<div class="mt-12">
				<div class="flex justify-center gap-5">
					<!-- GitHub -->
					<a 
						href="https://github.com/Eddou313" 
						target="_blank"
						rel="noopener noreferrer"
						aria-label="GitHub"
						class="w-12 h-12 flex items-center justify-center rounded-full bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-900 hover:text-white dark:hover:bg-white dark:hover:text-gray-900 transition-all hover:scale-110"
					>
						<svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
							<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
						</svg>
					</a>

					<!-- LinkedIn -->
					<a 
						href="https://linkedin.com/in/eddou-randrianarison-4a7746374" 
						target="_blank"
						rel="noopener noreferrer"
						aria-label="LinkedIn"
						class="w-12 h-12 flex items-center justify-center rounded-full bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-blue-600 hover:text-white transition-all hover:scale-110"
					>
						<svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
							<path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
						</svg>
					</a>

					<!-- Email -->
					<a 
						href="mailto:eddourandria@gmail.com"
						aria-label="Email"
						class="w-12 h-12 flex items-center justify-center rounded-full bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-red-500 hover:text-white transition-all hover:scale-110"
					>
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
						</svg>
					</a>

					<!-- WhatsApp -->
					<a 
						href="https://wa.me/+261327517278" 
						target="_blank"
						rel="noopener noreferrer"
						aria-label="WhatsApp"
						class="w-12 h-12 flex items-center justify-center rounded-full bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-green-500 hover:text-white transition-all hover:scale-110"
					>
						<svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
							<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
						</svg>
					</a>
				</div>
			</div>

			<!-- Scroll indicator -->
			<div class="mt-16 animate-bounce">
				<a href="#about" class="text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
					<svg class="w-6 h-6 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
					</svg>
				</a>
			</div>
		</div>
	</section>

	<!-- About Section -->
	<section id="about" class="min-h-screen py-20 px-4 bg-gray-50 dark:bg-gray-800/50 flex flex-col justify-center relative">
		<div class="max-w-6xl mx-auto">
			<!-- Section Title -->
			<div class="text-center mb-16">
				<h2 
					data-en="About Me" 
					data-fr="À propos de moi"
					class="about-text text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4"
				>
					About Me
				</h2>
				<div class="w-20 h-1 bg-indigo-600 mx-auto rounded-full"></div>
			</div>

			<div class="grid md:grid-cols-2 gap-12 items-center">
				<!-- Left: Image/Illustration -->
				<div class="flex justify-center">
					<div class="relative">
						<div class="w-72 h-72 md:w-80 md:h-80 rounded-2xl bg-gradient-to-br from-indigo-500 to-purple-600 p-1">
							<div class="w-full h-full rounded-2xl bg-gray-100 dark:bg-gray-900 flex items-center justify-center">
								<svg class="w-32 h-32 text-indigo-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
								</svg>
							</div>
						</div>
						<!-- Decorative elements -->
						<div class="absolute -top-4 -right-4 w-20 h-20 bg-indigo-200 dark:bg-indigo-900/50 rounded-full -z-10"></div>
						<div class="absolute -bottom-4 -left-4 w-16 h-16 bg-purple-200 dark:bg-purple-900/50 rounded-full -z-10"></div>
					</div>
				</div>

				<!-- Right: Content -->
				<div class="space-y-6">
					<p 
						data-en="I'm a passionate Full-Stack Developer based in Madagascar, with a strong focus on building modern, responsive, and user-friendly web applications." 
						data-fr="Je suis un développeur Full-Stack passionné basé à Madagascar, avec un fort accent sur la création d'applications web modernes, responsives et conviviales."
						class="about-text text-gray-600 dark:text-gray-300 leading-relaxed"
					>
						I'm a passionate Full-Stack Developer based in Madagascar, with a strong focus on building modern, responsive, and user-friendly web applications.
					</p>
					
					<p 
						data-en="I love turning complex problems into simple, beautiful solutions. When I'm not coding, you'll find me exploring new technologies and contributing to open-source projects." 
						data-fr="J'aime transformer des problèmes complexes en solutions simples et élégantes. Quand je ne code pas, vous me trouverez en train d'explorer de nouvelles technologies et de contribuer à des projets open-source."
						class="about-text text-gray-600 dark:text-gray-300 leading-relaxed"
					>
						I love turning complex problems into simple, beautiful solutions. When I'm not coding, you'll find me exploring new technologies and contributing to open-source projects.
					</p>

					<!-- Info Cards -->
					<div class="grid grid-cols-2 gap-4 pt-4">
						<div class="p-4 bg-white dark:bg-gray-800 rounded-xl shadow-sm">
							<p class="text-indigo-600 dark:text-indigo-400 font-bold text-2xl">2+</p>
							<p 
								data-en="Years Experience" 
								data-fr="Années d'expérience"
								class="about-text text-gray-600 dark:text-gray-400 text-sm"
							>
								Years Experience
							</p>
						</div>
						<div class="p-4 bg-white dark:bg-gray-800 rounded-xl shadow-sm">
							<p class="text-indigo-600 dark:text-indigo-400 font-bold text-2xl">10+</p>
							<p 
								data-en="Projects Completed" 
								data-fr="Projets réalisés"
								class="about-text text-gray-600 dark:text-gray-400 text-sm"
							>
								Projects Completed
							</p>
						</div>
					</div>


				</div>
			</div>
		</div>

		<!-- Scroll indicator -->
		<div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
			<a href="#skills" class="text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
				</svg>
			</a>
		</div>
	</section>

	<!-- Skills Section -->
	<section id="skills" class="min-h-screen py-20 px-4 flex flex-col justify-center relative">
		<div class="max-w-6xl mx-auto w-full">
			<!-- Section Title -->
			<div class="text-center mb-12">
				<h2 
					data-en="My Skills" 
					data-fr="Mes Compétences"
					class="section-text text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4"
				>
					My Skills
				</h2>
				<div class="w-20 h-1 bg-indigo-500 mx-auto rounded-full"></div>
			</div>

			<!-- Skills Grid 2x2 -->
			<div class="grid md:grid-cols-2 gap-6">
				<!-- Backend Card -->
				<div class="p-6 bg-slate-800/90 dark:bg-slate-900/90 rounded-2xl border border-indigo-500/30 shadow-lg shadow-indigo-500/10">
					<h3 class="text-xl font-bold text-indigo-400 mb-5 flex items-center gap-3">
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"/>
						</svg>
						Backend
					</h3>
					<div class="flex flex-wrap gap-3">
						<span class="px-4 py-2 bg-slate-700/60 text-slate-100 rounded-lg text-sm font-medium flex items-center gap-2 border border-indigo-500/30">
							<svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M7.01 10.207h-.944l-.515 2.648h.838c.556 0 .97-.105 1.242-.314.272-.21.455-.559.55-1.049.092-.47.05-.802-.124-.995-.175-.193-.523-.29-1.047-.29zM12 5.688C5.373 5.688 0 8.514 0 12s5.373 6.313 12 6.313S24 15.486 24 12c0-3.486-5.373-6.312-12-6.312zm-3.26 7.451c-.261.25-.575.438-.917.551-.336.108-.765.164-1.285.164H5.357l-.327 1.681H3.652l1.23-6.326h2.65c.797 0 1.378.209 1.744.628.366.418.476 1.002.33 1.752a2.836 2.836 0 0 1-.866 1.55z"/></svg>
							PHP Flight
						</span>
						<span class="px-4 py-2 bg-slate-700/60 text-slate-100 rounded-lg text-sm font-medium flex items-center gap-2 border border-indigo-500/30">
							<svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M7.01 10.207h-.944l-.515 2.648h.838c.556 0 .97-.105 1.242-.314.272-.21.455-.559.55-1.049.092-.47.05-.802-.124-.995-.175-.193-.523-.29-1.047-.29zM12 5.688C5.373 5.688 0 8.514 0 12s5.373 6.313 12 6.313S24 15.486 24 12c0-3.486-5.373-6.312-12-6.312z"/></svg>
							Laravel
						</span>
						<span class="px-4 py-2 bg-slate-700/60 text-slate-100 rounded-lg text-sm font-medium flex items-center gap-2 border border-indigo-500/30">
							<svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M8.851 18.56s-.917.534.653.714c1.902.218 2.874.187 4.969-.211 0 0 .552.346 1.321.646-4.699 2.013-10.633-.118-6.943-1.149M8.276 15.933s-1.028.761.542.924c2.032.209 3.636.227 6.413-.308 0 0 .384.389.987.602-5.679 1.661-12.007.13-7.942-1.218M13.116 11.475c1.158 1.333-.304 2.533-.304 2.533s2.939-1.518 1.589-3.418c-1.261-1.772-2.228-2.652 3.007-5.688 0-.001-8.216 2.051-4.292 6.573"/></svg>
							Spring Boot
						</span>
						<span class="px-4 py-2 bg-slate-700/60 text-slate-100 rounded-lg text-sm font-medium flex items-center gap-2 border border-indigo-500/30">
							<svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M8.851 18.56s-.917.534.653.714c1.902.218 2.874.187 4.969-.211 0 0 .552.346 1.321.646-4.699 2.013-10.633-.118-6.943-1.149"/></svg>
							Spring MVC
						</span>
						<span class="px-4 py-2 bg-slate-700/60 text-slate-100 rounded-lg text-sm font-medium flex items-center gap-2 border border-indigo-500/30">
							<svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M8.851 18.56s-.917.534.653.714c1.902.218 2.874.187 4.969-.211 0 0 .552.346 1.321.646-4.699 2.013-10.633-.118-6.943-1.149"/></svg>
							Java Swing
						</span>
						<span class="px-4 py-2 bg-slate-700/60 text-slate-100 rounded-lg text-sm font-medium flex items-center gap-2 border border-indigo-500/30">
							<svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M8.851 18.56s-.917.534.653.714c1.902.218 2.874.187 4.969-.211 0 0 .552.346 1.321.646-4.699 2.013-10.633-.118-6.943-1.149"/></svg>
							Java EE
						</span>
						<span class="px-4 py-2 bg-slate-700/60 text-slate-100 rounded-lg text-sm font-medium flex items-center gap-2 border border-indigo-500/30">
							<svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0z"/></svg>
							C#
						</span>
						<span class="px-4 py-2 bg-slate-700/60 text-slate-100 rounded-lg text-sm font-medium flex items-center gap-2 border border-indigo-500/30">
							<svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M14.25.18l.9.2.73.26.59.3.45.32.34.34.25.34.16.33.1.3.04.26.02.2-.01.13V8.5l-.05.63-.13.55-.21.46-.26.38-.3.31-.33.25-.35.19-.35.14-.33.1-.3.07-.26.04-.21.02H8.77l-.69.05-.59.14-.5.22-.41.27-.33.32-.27.35-.2.36-.15.37-.1.35-.07.32-.04.27-.02.21v3.06H3.17l-.21-.03-.28-.07-.32-.12-.35-.18-.36-.26-.36-.36-.35-.46-.32-.59-.28-.73-.21-.88-.14-1.05-.05-1.23.06-1.22.16-1.04.24-.87.32-.71.36-.57.4-.44.42-.33.42-.24.4-.16.36-.1.32-.05.24-.01h.16l.06.01h8.16v-.83H6.18l-.01-2.75-.02-.37.05-.34.11-.31.17-.28.25-.26.31-.23.38-.2.44-.18.51-.15.58-.12.64-.1.71-.06.77-.04.84-.02 1.27.05z"/></svg>
							Python Pandas
						</span>
						<span class="px-4 py-2 bg-slate-700/60 text-slate-100 rounded-lg text-sm font-medium flex items-center gap-2 border border-indigo-500/30">
							<svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M14.25.18l.9.2.73.26.59.3.45.32.34.34.25.34.16.33.1.3.04.26.02.2-.01.13V8.5l-.05.63-.13.55-.21.46-.26.38-.3.31-.33.25-.35.19-.35.14-.33.1-.3.07-.26.04-.21.02H8.77z"/></svg>
							Flask
						</span>
						<span class="px-4 py-2 bg-slate-700/60 text-slate-100 rounded-lg text-sm font-medium flex items-center gap-2 border border-indigo-500/30">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
							API REST
						</span>
						<span class="px-4 py-2 bg-slate-700/60 text-slate-100 rounded-lg text-sm font-medium flex items-center gap-2 border border-indigo-500/30">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
							Microservices
						</span>
					</div>
				</div>

				<!-- Frontend Card -->
				<div class="p-6 bg-slate-800/90 dark:bg-slate-900/90 rounded-2xl border border-indigo-500/30 shadow-lg shadow-indigo-500/10">
					<h3 class="text-xl font-bold text-indigo-400 mb-5 flex items-center gap-3">
						<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
						</svg>
						Frontend
